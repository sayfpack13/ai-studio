# Admin Configuration
ADMIN_PASSWORD=your-admin-password-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production

# Server Configuration
PORT=3001

# HuggingFace (optional)
# Token used for HuggingFace Inference Providers and private Spaces
HF_TOKEN=

# Image generation mode: inference | space
HF_IMAGE_MODE=space

# Inference provider (when HF_IMAGE_MODE=inference)
HF_IMAGE_PROVIDER=replicate

# Optional override for generic HF image Spaces
HF_IMAGE_SPACE_URL=

# Tongyi Space target. Set to your own duplicated Space to use your own quota.
# Example: username/your-z-image-space
HF_TONGYI_SPACE_URL=Tongyi-MAI/Z-Image-Turbo

# FLUX.1-dev Space target. Set to your own duplicated Space to use your own quota.
# Example: username/your-flux-space
HF_FLUX_SPACE_URL=black-forest-labs/FLUX.1-dev

# Optional override for generic HF video Spaces
HF_VIDEO_SPACE_URL=

# Wan 2.2 I2V A14B Space target. Set to your own duplicated Space to use your own quota.
# Example: username/your-wan-i2v-space
HF_WAN_I2V_A14B_SPACE_URL=r3gm/wan2-2-fp8da-aoti-preview