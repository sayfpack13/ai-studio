# Admin Configuration
ADMIN_PASSWORD=your-admin-password-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production

# Server Configuration
PORT=3001

# HuggingFace token — needed for ZeroGPU quota on public Spaces (PRO account recommended)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Image generation mode: space (public HF Spaces only)
HF_IMAGE_MODE=space

# Inference provider (when HF_IMAGE_MODE=inference)
HF_IMAGE_PROVIDER=replicate

# Optional override for generic HF image Spaces
HF_IMAGE_SPACE_URL=

# Tongyi Space target. Set to your own duplicated Space to use your own quota.
# Example: username/your-z-image-space
HF_TONGYI_SPACE_URL=Tongyi-MAI/Z-Image-Turbo

# FLUX.1-dev Space target. Set to your own duplicated Space to use your own quota.
# Example: username/your-flux-space
HF_FLUX_SPACE_URL=black-forest-labs/FLUX.1-dev

# Optional override for generic HF video Spaces
HF_VIDEO_SPACE_URL=

# Wan 2.2 I2V A14B Space target. Set to your own duplicated Space to use your own quota.
# Example: username/your-wan-i2v-space
HF_WAN_I2V_A14B_SPACE_URL=r3gm/wan2-2-fp8da-aoti-preview

# Optional: route ACE-Step through Replicate when ACEMUSIC_API_KEY is unset
# (~$0.03/run on dedicated GPU). Uses lucataco/ace-step.
REPLICATE_API_TOKEN=

# AceMusic — ACE-Step v1.5 API (required for Music Remixer).
# Cloud (api.acemusic.ai) uses /v1/chat/completions (completion mode).
# Self-hosted servers use /release_task + /query_result (native mode).
# Get your API key at: https://acemusic.ai/api-key
ACEMUSIC_API_KEY=
ACEMUSIC_BASE_URL=https://api.acemusic.ai
# Optional: force API mode — completion (cloud) or native (self-hosted)
# ACESTEP_API_MODE=completion
# Optional: trim cover uploads to N seconds (default: full track, only compresses large files)
# ACEMUSIC_MAX_COVER_SEC=90

# Optional HF Space fallback when ACEMUSIC_API_KEY and REPLICATE_API_TOKEN are unset
# HF_ACESTEP_SPACE_URL=ACE-Step/ACE-Step-1.5